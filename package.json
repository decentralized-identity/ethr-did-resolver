{
  "name": "ethr-did-resolver",
  "version": "12.0.0",
  "description": "Resolve DID documents for Ethereum addresses and public keys",
  "type": "commonjs",
  "source": "./src/index.ts",
  "main": "./lib/index.js",
  "module": "./esm/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./esm/index.js",
      "require": "./lib/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/decentralized-identity/ethr-did-resolver"
  },
  "files": [
    "lib",
    "esm",
    "src",
    "LICENSE"
  ],
  "author": "Pelle Braendgaard",
  "contributors": [
    "Mircea Nistor <work@mirceanis.xyz>"
  ],
  "license": "Apache-2.0",
  "keywords": [
    "did:ethr",
    "DID",
    "DID document",
    "PKI",
    "resolver",
    "Verifiable Credential",
    "W3C",
    "ethereum",
    "ethereumAddress",
    "blockchainAccountId",
    "registry",
    "EIP1056",
    "EcdsaSecp256k1RecoveryMethod2020",
    "EcdsaSecp256k1VerificationKey2019",
    "Ed25519VerificationKey2020",
    "X25519KeyAgreementKey2020",
    "Multikey"
  ],
  "scripts": {
    "test": "HARDHAT_CONFIG=hardhat.config.mts vitest run",
    "test:ci": "HARDHAT_CONFIG=hardhat.config.mts vitest run --coverage",
    "build": "tsc",
    "clean": "rm -rf ./lib",
    "format": "prettier --write \"src/**/*.[jt]s\"",
    "lint": "eslint \"src/**/*.[jt]s\"",
    "release": "semantic-release --debug"
  },
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/eslint-plugin": "1.6.16",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "hardhat": "3.4.4",
    "prettier": "3.8.3",
    "semantic-release": "25.0.3",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "did-resolver": "^5.0.1",
    "ethers": "^6.8.1"
  },
  "packageManager": "pnpm@10.33.4"
}
